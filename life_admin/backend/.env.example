# ── AI Keys ──────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-your-key-here
OPENAI_API_KEY=sk-your-whisper-key-here

# ── Database ──────────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-supabase-anon-key
DATABASE_URL=postgresql://user:password@localhost:5432/life_admin
REDIS_URL=redis://localhost:6379

# ── Google / MCP ─────────────────────────────────────────────
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALENDAR_SCOPES=https://www.googleapis.com/auth/calendar
GMAIL_SCOPES=https://www.googleapis.com/auth/gmail.readonly

# ── Notion ───────────────────────────────────────────────────
NOTION_API_KEY=ntn_your-notion-key
NOTION_DATABASE_ID=your-db-id

# ── Server ───────────────────────────────────────────────────
PORT=8001
DEBUG=True
CORS_ORIGINS=http://localhost:3000,http://10.0.2.2:3000
